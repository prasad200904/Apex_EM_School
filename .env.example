# Apex TM & EM School – Environment Variables
# Copy this file to .env and fill in your values

# Google Maps API Key (for Maps Embed)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend API URL (Node.js + Express server)
VITE_API_BASE_URL=http://localhost:5000

# MongoDB Connection String (for backend server)
MONGODB_URI=mongodb://localhost:27017/apex-school

# Server Port
PORT=5000

# School WhatsApp number (with country code, no +)
VITE_WHATSAPP_NUMBER=919393999674
